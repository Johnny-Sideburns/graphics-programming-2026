#version 430

layout(local_size_x = 64) in;

struct Strand
{
    vec4 pos;
};

layout(std430, binding = 0) buffer StrandBuffer
{
    Strand strands[];
};

void main()
{
    uint id = gl_GlobalInvocationID.x;

    strands[id].pos = vec4(
        float(id) * 0.01,
        0.0,
        0.0,
        1.0
    );
}